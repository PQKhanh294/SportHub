@page
@model SportHub.Pages.Profile.EditModel
@{
    ViewData["Title"] = "Edit Profile";
}

<section class="max-w-3xl mx-auto space-y-6">
    <div>
        <h1 class="text-3xl font-black tracking-tight">Edit Profile</h1>
        <p class="text-slate-500 dark:text-slate-400">Update your personal information.</p>
    </div>

    <form method="post" enctype="multipart/form-data" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 space-y-5 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-500"></div>

        <div>
            <label class="block text-sm font-semibold mb-2">Full name</label>
            <input asp-for="Input.FullName" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
            <span asp-validation-for="Input.FullName" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Phone number</label>
            <input asp-for="Input.PhoneNumber" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
            <span asp-validation-for="Input.PhoneNumber" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Upload avatar (from your computer)</label>
            <input asp-for="AvatarFile" type="file" accept=".jpg,.jpeg,.png,.webp,image/*" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
            <span asp-validation-for="AvatarFile" class="text-xs text-red-500"></span>
            <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Supported formats: JPG, PNG, WEBP (max 2MB).</p>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Or use avatar URL (optional)</label>
            <input asp-for="Input.AvatarUrl" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" placeholder="https://..." />
            <span asp-validation-for="Input.AvatarUrl" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Skill level</label>
            <select asp-for="Input.SkillLevel" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800">
                <option value="">Keep current</option>
                <option>Beginner</option>
                <option>Intermediate</option>
                <option>Advanced</option>
                <option>Professional</option>
            </select>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary/90">Save changes</button>
            <a asp-page="/Profile/Index" class="px-6 py-2.5 bg-slate-100 dark:bg-slate-800 rounded-lg font-bold">Back</a>
        </div>
    </form>
</section>
