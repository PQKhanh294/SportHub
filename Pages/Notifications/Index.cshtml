@page
@{
    ViewData["Title"] = "Notifications";
}

<section class="space-y-6">
    <div>
        <h1 class="text-4xl font-black tracking-tight">Notifications</h1>
        <p class="text-slate-500 dark:text-slate-400">Latest updates on bookings, payments, and matchmaking.</p>
    </div>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
        <div class="divide-y divide-slate-100 dark:divide-slate-800">
            <article class="p-5 flex items-start gap-4">
                <span class="material-symbols-outlined text-primary">calendar_today</span>
                <div>
                    <p class="font-semibold">Your booking at Riverside Tennis Club has been confirmed.</p>
                    <p class="text-sm text-slate-500 dark:text-slate-400">2 minutes ago</p>
                </div>
            </article>
            <article class="p-5 flex items-start gap-4">
                <span class="material-symbols-outlined text-emerald-500">payments</span>
                <div>
                    <p class="font-semibold">Payment successful: $45.00 for Elite Padel Court Center.</p>
                    <p class="text-sm text-slate-500 dark:text-slate-400">12 minutes ago</p>
                </div>
            </article>
            <article class="p-5 flex items-start gap-4">
                <span class="material-symbols-outlined text-amber-500">person_add</span>
                <div>
                    <p class="font-semibold">You have a new match invite: Intermediate doubles match.</p>
                    <p class="text-sm text-slate-500 dark:text-slate-400">1 hour ago</p>
                </div>
            </article>
        </div>
    </div>
</section>
