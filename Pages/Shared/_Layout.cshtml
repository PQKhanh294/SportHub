<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sport Hub</title>

    <!--
    ================================================================
    SPORT HUB — SHARED LAYOUT
    Nguồn thiết kế: Stitch MCP (project 17073324636926099521)
    Quy tắc: HTML5 + Tailwind CSS CDN + Vanilla JS ONLY (NO React/Vue)
    ================================================================
    -->

    <!-- Tailwind CSS CDN với plugins chính thức -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Google Fonts: Inter (font chính của thiết kế) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Material Symbols Outlined (icon library của thiết kế) -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Tailwind Custom Config — Màu chủ đạo từ thiết kế Stitch -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary":            "#2560e9",  /* Màu brand chính */
                        "background-light":   "#f6f6f8",
                        "background-dark":    "#111621",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "lg":      "1rem",
                        "xl":      "1.5rem",
                        "full":    "9999px"
                    },
                },
            },
        }
    </script>

    <!-- Site CSS (scrollbar & badge utilities) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @* Cho phép từng trang thêm CSS riêng *@
    @await RenderSectionAsync("Styles", required: false)
</head>

@using System.Security.Claims
@inject SportHub.Services.Interfaces.IUserService UserService

@{
    string? currentUserAvatar = null;
    if (User.Identity?.IsAuthenticated == true)
    {
        var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (int.TryParse(userIdClaim, out var currentUserId) && currentUserId > 0)
        {
            var currentUser = await UserService.GetUserByIdAsync(currentUserId);
            currentUserAvatar = currentUser?.AvatarUrl;
        }
    }
}

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">

<!-- ================================================================
     NAVBAR — Thanh điều hướng cố định trên đầu
     (Trích xuất 1:1 từ Stitch MCP Home Page)
     ================================================================ -->
<header class="sticky top-0 z-50 w-full bg-white/80 dark:bg-background-dark/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            <!-- Logo -->
            <div class="flex items-center gap-2">
                <div class="text-primary">
                    <span class="material-symbols-outlined text-3xl">sports_tennis</span>
                </div>
                <a asp-page="/Index" class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">Sport Hub</a>
            </div>

            <!-- Navigation Links (Desktop) -->
            <nav class="hidden md:flex items-center space-x-8">
                <a asp-page="/Index"
                   class="@(ViewData["ActivePage"]?.ToString() == "Home" ? "text-primary font-semibold border-b-2 border-primary pb-1" : "text-slate-600 dark:text-slate-400 hover:text-primary") text-sm font-medium transition-colors">
                    Home
                </a>
                <a asp-page="/Matchmaking/Index"
                   class="@(ViewData["ActivePage"]?.ToString() == "Matchmaking" ? "text-primary font-semibold border-b-2 border-primary pb-1" : "text-slate-600 dark:text-slate-400 hover:text-primary") text-sm font-medium transition-colors">
                    Matchmaking
                </a>
                <a asp-page="/Courts/Search"
                   class="@(ViewData["ActivePage"]?.ToString() == "SearchCourts" ? "text-primary font-semibold border-b-2 border-primary pb-1" : "text-slate-600 dark:text-slate-400 hover:text-primary") text-sm font-medium transition-colors">
                    Search Courts
                </a>
                <a asp-page="/Bookings/MyBookings"
                   class="@(ViewData["ActivePage"]?.ToString() == "Bookings" ? "text-primary font-semibold border-b-2 border-primary pb-1" : "text-slate-600 dark:text-slate-400 hover:text-primary") text-sm font-medium transition-colors">
                    Bookings
                </a>
                <a asp-page="/Profile/Index"
                   class="@(ViewData["ActivePage"]?.ToString() == "Profile" ? "text-primary font-semibold border-b-2 border-primary pb-1" : "text-slate-600 dark:text-slate-400 hover:text-primary") text-sm font-medium transition-colors">
                    Profile
                </a>
            </nav>

            <!-- User Actions -->
            <div class="flex items-center gap-4">
                <!-- Notification Bell -->
                <a asp-page="/Notifications/Index" class="p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-full transition-colors">
                    <span class="material-symbols-outlined">notifications</span>
                </a>

                <!-- Avatar người dùng hiện tại -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="flex items-center gap-2">
                        <a asp-page="/Profile/Index" class="size-10 rounded-full bg-primary/10 border-2 border-primary/20 overflow-hidden block">
                            <img class="w-full h-full object-cover"
                                 src="@(string.IsNullOrWhiteSpace(currentUserAvatar) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(User.Identity?.Name ?? "Sport Hub")}&background=E2E8F0&color=1E293B" : currentUserAvatar)"
                                 onerror="this.onerror=null;this.src='https://ui-avatars.com/api/?name=Sport+Hub&background=E2E8F0&color=1E293B';"
                                 alt="@User.Identity.Name" />
                        </a>
                        <form method="post" asp-page="/Auth/Logout">
                            <button type="submit" class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors">
                                Logout
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="flex items-center gap-2">
                        <a asp-page="/Auth/Login"
                           class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors">
                            Login
                        </a>
                        <a asp-page="/Auth/Register"
                           class="bg-primary hover:bg-primary/90 text-white text-sm font-bold py-2 px-4 rounded-lg transition-all">
                            Register
                        </a>
                    </div>
                }

                <!-- Hamburger Mobile -->
                <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 dark:text-slate-400 hover:bg-slate-100 rounded-full">
                    <span class="material-symbols-outlined">menu</span>
                </button>
            </div>

        </div>

        <!-- Mobile Nav Dropdown -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
            <nav class="flex flex-col space-y-1 pt-2">
                <a asp-page="/Index" class="px-3 py-2 text-sm font-medium rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">Home</a>
                <a asp-page="/Matchmaking/Index" class="px-3 py-2 text-sm font-medium rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">Matchmaking</a>
                <a asp-page="/Courts/Search" class="px-3 py-2 text-sm font-medium rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">Search Courts</a>
                <a asp-page="/Bookings/MyBookings" class="px-3 py-2 text-sm font-medium rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">Bookings</a>
                <a asp-page="/Profile/Index" class="px-3 py-2 text-sm font-medium rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">Profile</a>
            </nav>
        </div>

    </div>
</header>

<!-- ================================================================
     MAIN CONTENT — Từng trang Razor sẽ render vào đây
     ================================================================ -->
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    @* Toast Notifications (TempData) *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="fixed top-20 right-4 z-50 bg-emerald-500 text-white px-6 py-3 rounded-xl shadow-lg flex items-center gap-2 animate-pulse" id="toast-success">
            <span class="material-symbols-outlined">check_circle</span>
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="fixed top-20 right-4 z-50 bg-red-500 text-white px-6 py-3 rounded-xl shadow-lg flex items-center gap-2" id="toast-error">
            <span class="material-symbols-outlined">error</span>
            @TempData["ErrorMessage"]
        </div>
    }

    @RenderBody()
</main>

<!-- ================================================================
     FOOTER — Trích xuất 1:1 từ Stitch MCP Home Page
     ================================================================ -->
<footer class="bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

        <div class="flex flex-col md:flex-row justify-between items-center gap-8">

            <!-- Logo -->
            <div class="flex items-center gap-2">
                <div class="text-primary">
                    <span class="material-symbols-outlined text-3xl">sports_tennis</span>
                </div>
                <span class="text-xl font-bold tracking-tight text-slate-900 dark:text-white">Sport Hub</span>
            </div>

            <!-- Footer Links -->
            <div class="flex flex-wrap justify-center gap-8 text-sm font-medium text-slate-500 dark:text-slate-400">
                <a class="hover:text-primary transition-colors" href="#">About Us</a>
                <a class="hover:text-primary transition-colors" href="#">Community Guidelines</a>
                <a class="hover:text-primary transition-colors" href="#">Privacy Policy</a>
                <a class="hover:text-primary transition-colors" href="#">Terms of Service</a>
                <a class="hover:text-primary transition-colors" href="#">Help Center</a>
            </div>

            <!-- Social Icons -->
            <div class="flex gap-4">
                <a class="size-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-all" href="#">
                    <span class="material-symbols-outlined">share</span>
                </a>
                <a class="size-10 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-all" href="#">
                    <span class="material-symbols-outlined">chat</span>
                </a>
            </div>

        </div>

        <!-- Copyright -->
        <div class="mt-8 pt-8 border-t border-slate-100 dark:border-slate-800 text-center text-slate-400 text-xs">
            &copy; @DateTime.Now.Year Sport Hub. All rights reserved.
        </div>

    </div>
</footer>

<!-- ================================================================
     VANILLA JS — Mobile menu toggle + Toast auto-dismiss
     ================================================================ -->
<script>
    // Mobile menu toggle
    const btn  = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
        btn.addEventListener('click', () => menu.classList.toggle('hidden'));
    }

    // Auto-dismiss toast sau 3 giây
    ['toast-success', 'toast-error'].forEach(id => {
        const el = document.getElementById(id);
        if (el) setTimeout(() => el.remove(), 3000);
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
