@page
@model IndexModel
@{
    ViewData["Title"] = "Find Your Perfect Match";
}

<!-- HERO BANNER -->
<section class="relative rounded-xl lg:rounded-xl overflow-hidden mb-12">
    <!-- Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-slate-900/80 via-slate-900/40 to-transparent z-10"></div>
    <img class="absolute inset-0 w-full h-full object-cover"
         src="https://lh3.googleusercontent.com/aida-public/AB6AXuBmGtp-E7wKffkiMg5OFbwJkMPjcwBCct6fIes50GOGGnfwebfE1luz7m4DXWxhLl48Ui5k5kei8zBuVNgYWt5JBfj0JlT-GO6YLXgTRS0JhKlsDMQIRdbDl5rE42BONc9CPK88iiHoz3Gb1XgqJ4OnQKldIKVRgW_5WDW1AQl8SK3s5PlyJWUFWizXl-rnBSVlp-7M8J3RqB16jP43p5UwfdTL-a-Am9pVT372KkNwIF9CFttBJy-Kqe_WHRK92o1BD04EVLvdmsk"
         alt="Hero background" />
    
    <!-- Hero Content -->
    <div class="relative z-20 px-8 py-20 md:py-32 lg:px-16 max-w-2xl">
        <h1 class="text-4xl md:text-6xl font-black text-white leading-tight mb-4">
            Find Your Perfect Match
        </h1>
        <p class="text-lg text-slate-200 mb-8 max-w-lg">
            Join the largest racket sports community. Connect with players of your level and book quality courts instantly.
        </p>
        <div class="flex flex-wrap gap-4">
            <a asp-page="/Matchmaking/Index" class="bg-primary hover:bg-primary/90 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-primary/30 flex items-center gap-2">
                <span class="material-symbols-outlined">person_search</span>
                Find Players
            </a>
            <a asp-page="/Courts/Search" class="bg-white/10 hover:bg-white/20 backdrop-blur-md text-white border border-white/30 font-bold py-3 px-8 rounded-xl transition-all flex items-center gap-2">
                <span class="material-symbols-outlined">calendar_today</span>
                Book Court
            </a>
        </div>
    </div>
</section>

<!-- RECOMMENDED MATCHES -->
<section class="mb-12">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Recommended Matches</h2>
        <a asp-page="/Matchmaking/Index" class="text-primary font-semibold text-sm hover:underline">View all</a>
    </div>

    <div class="flex gap-6 overflow-x-auto pb-4 hide-scrollbar">
        @foreach (var match in Model.RecommendedMatches)
        {
            <div class="min-w-[300px] bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                <div class="relative h-40">
                    <img class="w-full h-full object-cover" src="@match.CourtImageUrl" alt="@match.Title" />
                    <div class="absolute top-3 right-3 text-white text-xs font-bold px-3 py-1 rounded-full @match.BadgeCssClass">
                        @match.MatchCategory
                    </div>
                </div>
                <div class="p-5">
                    <h3 class="font-bold text-lg mb-1 truncate">@match.Title</h3>
                    <div class="flex items-center text-slate-500 dark:text-slate-400 text-sm gap-2 mb-4 truncate">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        @match.DateTimeDisplay
                        <span class="mx-1">•</span>
                        <span class="material-symbols-outlined text-sm">location_on</span>
                        @match.VenueName
                    </div>
                    <div class="flex items-center justify-between">
                        <div class="flex -space-x-2">
                            @foreach (var avatar in match.ParticipantAvatars.Take(3))
                            {
                                <img class="size-8 rounded-full border-2 border-white dark:border-slate-900" src="@avatar" alt="Player" />
                            }
                            @if (match.CurrentParticipants > 3)
                            {
                                <div class="size-8 rounded-full border-2 border-white dark:border-slate-900 bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-[10px] font-bold">
                                    +@(match.CurrentParticipants - 3)
                                </div>
                            }
                        </div>
                        <a asp-page="/Matchmaking/Details" asp-route-id="@match.MatchID" class="bg-primary/10 hover:bg-primary/20 text-primary font-bold px-4 py-2 rounded-lg text-sm transition-colors">
                            Join
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
    <!-- SUGGESTED PLAYERS -->
    <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Suggested Players</h2>
            <a asp-page="/Players/Index" class="text-primary font-semibold text-sm hover:underline">See more</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var player in Model.SuggestedPlayers)
            {
                <div class="flex items-center p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl hover:shadow-sm transition-shadow">
                    <img class="size-16 rounded-full object-cover" src="@player.AvatarUrl" alt="@player.FullName" />
                    <div class="ml-4 flex-1">
                        <h4 class="font-bold text-slate-900 dark:text-white">@player.FullName</h4>
                        <p class="text-slate-500 text-sm">@player.FavoriteSport • @player.SkillLevel</p>
                        <div class="flex items-center mt-1">
                            <span class="material-symbols-outlined text-amber-400 text-xs">star</span>
                            <span class="text-xs font-bold ml-1">@player.AverageRating.ToString("F1")</span>
                            <span class="text-slate-400 text-xs ml-1">(@player.TotalMatches matches)</span>
                        </div>
                    </div>
                    <a asp-page="/Players/Index" class="p-2 text-primary bg-primary/10 rounded-full hover:bg-primary/20 transition-colors" title="View players list">
                        <span class="material-symbols-outlined">person_add</span>
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- NEARBY COURTS -->
    <div>
        <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white">Nearby Courts</h2>
            <a asp-page="/Courts/Map" class="text-primary font-semibold text-sm hover:underline">Map</a>
        </div>
        <div class="space-y-4">
            @foreach (var court in Model.NearbyCourts)
            {
                <a asp-page="/Courts/Details" asp-route-id="@court.CourtID" class="flex gap-4 group cursor-pointer bg-white dark:bg-slate-900 p-2 rounded-xl hover:shadow-md transition-shadow">
                    <div class="size-20 shrink-0 rounded-lg overflow-hidden bg-slate-200">
                        <img class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" src="@court.MainImageUrl" alt="@court.VenueName" />
                    </div>
                    <div class="flex-1">
                        <h4 class="font-bold text-slate-900 dark:text-white group-hover:text-primary transition-colors">@court.VenueName</h4>
                        <p class="text-slate-500 text-xs mb-1">@court.DistanceKm.ToString() km • @court.TotalCourts courts</p>
                        
                        @if (court.Availability == CourtCardViewModel.AvailabilityStatus.Available)
                        {
                            <span class="text-emerald-500 text-xs font-bold flex items-center">
                                <span class="size-2 bg-emerald-500 rounded-full mr-1.5 animate-pulse"></span>Available
                            </span>
                        }
                        else if (court.Availability == CourtCardViewModel.AvailabilityStatus.Limited)
                        {
                            <span class="text-amber-500 text-xs font-bold flex items-center">
                                <span class="size-2 bg-amber-500 rounded-full mr-1.5"></span>Limited slots
                            </span>
                        }
                        else
                        {
                            <span class="text-red-500 text-xs font-bold flex items-center">
                                <span class="size-2 bg-red-500 rounded-full mr-1.5"></span>Full
                            </span>
                        }
                        
                        <p class="text-primary font-bold text-sm mt-1">@court.MinPricePerHour.ToString("N0") VND/hour</p>
                    </div>
                </a>
            }
        </div>

        <!-- Map Thumbnail -->
        <a asp-page="/Courts/Map" class="mt-6 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 h-40 relative group block">
            <img class="w-full h-full object-cover grayscale opacity-50 dark:invert group-hover:scale-105 transition-transform duration-500"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuADgOSzYyJd8j5uc75VgmP67HRNrgeWnvBL4yajbnb-aPZr6yMk28wDKQho0ZwWQBRQ7p3W_AC_GaKCyerzl2t6vH66rh_utJjsk7cm2LGCus1cYe4gNk74NzmD9VzzpHz60fqRltVaYj5L_D_wPAMMdQ2KmQEgIC_tEAHUMTZrEuSFPMWdriZfD9XiuCpBNaaiJOZSYLO_Rn3TvO6qhrJSPd5A7EzDquBmNFn4se3uc_2D2QZTqIiTrnNhs2PJAgCIDihpPNihNTM"
                 alt="Map view" />
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white font-bold py-2 px-4 rounded-lg shadow-lg text-sm flex items-center gap-2 group-hover:bg-primary group-hover:text-white transition-colors">
                    <span class="material-symbols-outlined">map</span>
                    Explore map
                </div>
            </div>
        </a>
    </div>
</div>
