@page "{id:int?}"
@model SportHub.Pages.Matchmaking.DetailsModel
@{
    ViewData["Title"] = "Match Details";
    var item = Model.Item;
}

@if (item == null)
{
    <section class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
        <p class="text-slate-500 dark:text-slate-400">Match not found.</p>
    </section>
}
else
{

<section class="grid grid-cols-1 lg:grid-cols-12 gap-8">
    <div class="lg:col-span-8 space-y-6">
        <article class="bg-white dark:bg-slate-900 rounded-xl overflow-hidden border border-slate-200 dark:border-slate-800 shadow-sm">
            <div class="relative h-64">
                <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBuyetq-CjYniznRR2LQD8js1JDRvgAYveuoCNhfGsauk1CP-z2TywH1K-Xw5PoaJMxXqGfqFgGgDkMEgzi9rE2IjqCKCiiBCpyawFJCUII3zFhqq7ebqAlP1YZux0CAcfosVIK1Ru7RwxZqtC-tnt4OKa5N3qc919AjX0s1MzA5BQdsghli12q44PqbEusnjtcTT0Z1PbUvJZ-pHdJoDiRLPBOMKoQZYZLlGQ2lrBdViOvLJ4XVCkjH6QzdDesUC1Qk_Z_pnK3_GE" alt="Match" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-5 left-5 text-white">
                    <span class="inline-block px-3 py-1 bg-primary text-xs font-bold rounded-full mb-2">@item.MatchType</span>
                    <h1 class="text-3xl font-black">@item.Title</h1>
                </div>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-3 text-sm">
                    <p><b>Date:</b> @item.DateText</p>
                    <p><b>Time:</b> @item.TimeText</p>
                    <p><b>Location:</b> @item.Venue</p>
                    <p><b>Court name:</b> @item.CourtName</p>
                    <p><b>Court address:</b> @item.CourtAddress</p>
                    <p><b>Skill level:</b> @item.SkillRequired</p>
                    <p><b>Players:</b> @item.Participants.Count / @item.MaxParticipants joined</p>
                </div>
                <div class="bg-background-light dark:bg-slate-800 rounded-lg p-4">
                    <p class="text-sm text-slate-500">Participation price</p>
                    <p class="text-xl font-bold text-primary mb-3">@item.PriceDisplay</p>
                    <p class="text-sm text-slate-500">Remaining spots</p>
                    <p class="text-xl font-bold text-primary">@item.SpotsLeft spots</p>
                </div>
            </div>
        </article>
    </div>
    <aside class="lg:col-span-4 space-y-6">
        <div class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 shadow-sm">
            <h2 class="font-bold mb-4">Participants</h2>
            <div class="space-y-3 text-sm text-slate-600 dark:text-slate-300">
                @if (item.Participants.Count == 0)
                {
                    <p>No participants yet.</p>
                }
                else
                {
                    @foreach (var participant in item.Participants)
                    {
                        <p>@participant</p>
                    }
                }
            </div>
            @if (item.IsJoined)
            {
                <button type="button" class="mt-5 inline-flex w-full justify-center px-4 py-2 rounded-lg bg-emerald-100 text-emerald-700 font-bold cursor-default">Joined</button>
            }
            else if (item.CanJoin)
            {
                <form method="post" asp-page-handler="Join" class="mt-5">
                    <input type="hidden" name="id" value="@item.MatchId" />
                    <button type="submit" class="inline-flex w-full justify-center px-4 py-2 rounded-lg bg-primary text-white font-bold hover:bg-primary/90">Join match</button>
                </form>
            }
            else
            {
                <button type="button" class="mt-5 inline-flex w-full justify-center px-4 py-2 rounded-lg bg-slate-200 text-slate-500 font-bold cursor-not-allowed">Unavailable to join</button>
            }

            @if (item.IsOwner)
            {
                <a asp-page="/Matchmaking/Edit" asp-route-id="@item.MatchId" class="mt-3 inline-flex w-full justify-center px-4 py-2 rounded-lg bg-slate-100 dark:bg-slate-800 font-bold">Edit your match</a>
            }

            <a asp-page="/Matchmaking/Index" class="mt-5 inline-flex w-full justify-center px-4 py-2 rounded-lg bg-primary text-white font-bold">Back to matchmaking</a>
        </div>
    </aside>
</section>

}
