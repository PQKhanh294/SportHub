@page "{id:int}"
@model SportHub.Pages.Matchmaking.EditModel
@{
    ViewData["Title"] = "Edit Match";
}

<section class="max-w-3xl mx-auto space-y-6">
    <div>
        <h1 class="text-3xl font-black tracking-tight">Edit Match</h1>
        <p class="text-slate-500 dark:text-slate-400">Update your match information.</p>
    </div>

    <form method="post" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-6 space-y-5 shadow-sm">
        <input asp-for="Input.MatchId" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-500"></div>

        <div>
            <label class="block text-sm font-semibold mb-2">Match title</label>
            <input asp-for="Input.Title" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
            <span asp-validation-for="Input.Title" class="text-xs text-red-500"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2">Court (optional ID)</label>
                <input asp-for="Input.CourtId" type="number" min="1" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.CourtId" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Sport</label>
                <select asp-for="Input.SportId" asp-items="Model.SportOptions" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800">
                    <option value="">Select sport</option>
                </select>
                <span asp-validation-for="Input.SportId" class="text-xs text-red-500"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2">Court name (optional)</label>
                <input asp-for="Input.CourtName" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.CourtName" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Court address (optional)</label>
                <input asp-for="Input.CourtAddress" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.CourtAddress" class="text-xs text-red-500"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2">Match date</label>
                <input asp-for="Input.MatchDate" type="date" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.MatchDate" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Start time</label>
                <input asp-for="Input.StartTime" type="time" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.StartTime" class="text-xs text-red-500"></span>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">End time</label>
                <input asp-for="Input.EndTime" type="time" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.EndTime" class="text-xs text-red-500"></span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2">Match type</label>
                <select asp-for="Input.MatchType" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800">
                    <option value="Singles">Singles</option>
                    <option value="Doubles">Doubles</option>
                    <option value="Mixed">Mixed</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Required skill level</label>
                <select asp-for="Input.SkillRequired" asp-items="Model.SkillOptions" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800"></select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Max participants</label>
                <input asp-for="Input.MaxParticipants" type="number" min="2" max="20" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
                <span asp-validation-for="Input.MaxParticipants" class="text-xs text-red-500"></span>
            </div>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Match price (VND, optional)</label>
            <input asp-for="Input.PriceVnd" type="number" min="0" step="1000" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800" />
            <span asp-validation-for="Input.PriceVnd" class="text-xs text-red-500"></span>
        </div>

        <div>
            <label class="block text-sm font-semibold mb-2">Description</label>
            <textarea asp-for="Input.Description" rows="3" class="w-full rounded-lg border-slate-300 dark:border-slate-700 dark:bg-slate-800"></textarea>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-lg font-bold hover:bg-primary/90">Save changes</button>
            <a asp-page="/Matchmaking/Details" asp-route-id="@Model.Input.MatchId" class="px-6 py-2.5 bg-slate-100 dark:bg-slate-800 rounded-lg font-bold">Back</a>
        </div>
    </form>
</section>
