@page
@model SportHub.Pages.Bookings.MyBookingsModel
@{
    ViewData["Title"] = "My Bookings";
}

<section class="space-y-6">
    <div class="max-w-[1024px] mx-auto space-y-6">
    <div class="space-y-1">
        <h1 class="text-4xl font-black tracking-tight text-slate-900 dark:text-white">My Bookings</h1>
        <p class="text-slate-500 dark:text-slate-400">Manage your game schedule and court reservations</p>
    </div>

    <div class="border-b border-slate-200 dark:border-slate-800">
        <div class="flex gap-8 overflow-x-auto no-scrollbar">
            <a asp-page="/Bookings/MyBookings" asp-route-tab="all" class="border-b-2 @(Model.ActiveTab == "all" ? "border-primary text-primary" : "border-transparent text-slate-500 dark:text-slate-400") pb-3 pt-2 text-sm font-bold whitespace-nowrap">All</a>
            <a asp-page="/Bookings/MyBookings" asp-route-tab="upcoming" class="border-b-2 @(Model.ActiveTab == "upcoming" ? "border-primary text-primary" : "border-transparent text-slate-500 dark:text-slate-400") pb-3 pt-2 text-sm font-bold whitespace-nowrap">Upcoming</a>
            <a asp-page="/Bookings/MyBookings" asp-route-tab="completed" class="border-b-2 @(Model.ActiveTab == "completed" ? "border-primary text-primary" : "border-transparent text-slate-500 dark:text-slate-400") pb-3 pt-2 text-sm font-bold whitespace-nowrap">Completed</a>
            <a asp-page="/Bookings/MyBookings" asp-route-tab="cancelled" class="border-b-2 @(Model.ActiveTab == "cancelled" ? "border-primary text-primary" : "border-transparent text-slate-500 dark:text-slate-400") pb-3 pt-2 text-sm font-bold whitespace-nowrap">Cancelled</a>
        </div>
    </div>

    <div class="space-y-5 py-2">
        @if (Model.Items.Count == 0)
        {
            <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 text-center">
                <p class="text-slate-500 dark:text-slate-400">No bookings found for this tab.</p>
            </div>
        }
        else
        {
            @foreach (var item in Model.Items)
            {
                <article class="flex flex-col md:flex-row items-stretch gap-6 p-5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900/50 shadow-sm @(item.IsCancelled ? "opacity-80" : "hover:shadow-md transition-shadow")">
                    <img class="w-full md:w-60 h-40 rounded-lg object-cover @(item.IsCancelled ? "grayscale" : "")" src="@item.ImageUrl" alt="Court" />
                    <div class="flex-1 flex flex-col justify-between gap-4">
                        <div>
                            <div class="flex items-start justify-between">
                                <h3 class="text-xl font-bold text-slate-900 dark:text-white">@item.VenueName</h3>
                                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold @item.StatusBadgeClass">@item.DisplayStatus</span>
                            </div>
                            <div class="mt-3 space-y-2 text-sm @(item.IsCancelled ? "text-slate-400 dark:text-slate-500" : "text-slate-500 dark:text-slate-400")">
                                <p class="@(item.IsCancelled ? "line-through" : "") flex items-center gap-2"><span class="material-symbols-outlined text-base">calendar_today</span>@item.BookingDate.ToString("MMM dd, yyyy")</p>
                                <p class="@(item.IsCancelled ? "line-through" : "") flex items-center gap-2"><span class="material-symbols-outlined text-base">schedule</span>@item.TimeDisplay</p>
                                @if (!string.IsNullOrWhiteSpace(item.RefundDisplay))
                                {
                                    <p class="font-semibold flex items-center gap-2"><span class="material-symbols-outlined text-base">payments</span>@item.RefundDisplay</p>
                                }
                                else
                                {
                                    <p class="font-semibold text-slate-800 dark:text-slate-200 flex items-center gap-2"><span class="material-symbols-outlined text-base">payments</span>Total: @item.TotalPriceDisplay</p>
                                }
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <a asp-page="/Courts/Details" asp-route-id="@item.CourtId" class="px-6 py-2 bg-primary text-white rounded-lg text-sm font-bold hover:bg-primary/90">View details</a>
                            @if (item.CanCancel)
                            {
                                <form method="post" asp-page-handler="Cancel">
                                    <input type="hidden" name="bookingId" value="@item.BookingId" />
                                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                                    <button type="submit" class="px-6 py-2 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-lg text-sm font-bold">Cancel booking</button>
                                </form>
                            }
                            else
                            {
                                <button class="px-6 py-2 bg-slate-200 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-lg text-sm font-bold cursor-not-allowed">Unavailable</button>
                            }
                        </div>
                    </div>
                </article>
            }
        }
    </div>
    </div>
</section>
