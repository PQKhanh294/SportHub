@page
@model SportHub.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";
}

<section class="relative overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-800 min-h-[78vh]">
    <img class="absolute inset-0 w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBqFm-aKP5EiL6q4BUrYnrOkr3P1MOFlI23qXs44yF0IIpGLNOl9Ne0xtH345c0ogmqAGgr7UXvo5AGIzk7O4g21CS8S9__eCz1vYYMR9OTmF_fDmqTUbunaEPwHsZZ0ywkP_bRSlae0vOnNpTmZpQtOMUSiga_lRYfKev5qw9VNqFjikaM53-zrAwScQ__km5awA7jvVdOtGEs7uyB8uWkPKvjh8NAViagalz3vXsc-54fQsHos1eeZOE5n4F1gH--M7jRKzE1npU" alt="Tennis court" />
    <div class="absolute inset-0 bg-slate-900/65"></div>

    <div class="relative z-10 flex items-center justify-center min-h-[78vh] p-6">
        <div class="w-full max-w-[480px] bg-white/95 dark:bg-slate-900/95 rounded-xl border border-white/20 dark:border-slate-700 shadow-2xl">
            <div class="px-8 pt-10 pb-6 text-center">
                <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-white">Welcome back</h1>
                <p class="mt-2 text-slate-500 dark:text-slate-400">Log in to your Sport Hub account</p>
            </div>

            <form method="post" class="px-8 pb-10 space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-sm text-red-500"></div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Email address</label>
                    <input asp-for="Input.Email" type="email" class="w-full h-12 px-4 rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-primary" placeholder="Enter your email" />
                    <span asp-validation-for="Input.Email" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-slate-700 dark:text-slate-300">Password</label>
                    <input asp-for="Input.Password" type="password" class="w-full h-12 px-4 rounded-lg border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-800 placeholder:text-slate-400 focus:ring-2 focus:ring-primary" placeholder="Enter your password" />
                    <span asp-validation-for="Input.Password" class="text-xs text-red-500"></span>
                </div>

                <button type="submit" class="w-full h-12 bg-primary hover:bg-primary/90 text-white font-bold rounded-lg shadow-md transition-all">Log in</button>

                <p class="text-center text-sm text-slate-600 dark:text-slate-400">
                    Don't have an account?
                    <a asp-page="/Auth/Register" class="font-bold text-primary hover:underline ml-1">Register now</a>
                </p>
            </form>
        </div>
    </div>
</section>
